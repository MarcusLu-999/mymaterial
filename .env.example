# Server port configuration
PORT=3001

# Internal LLM Gateway Configuration
# Point this to your company's internal OpenAI-compatible model API gateway
OPENAI_API_BASE_URL=http://internal-llm-gateway.company.com/v1
OPENAI_API_KEY=your-internal-jwt-or-api-key-here

# Selected LLM Model Name (e.g., gpt-4o, llama-3-70b-instruct)
OPENAI_MODEL_NAME=gpt-4o
